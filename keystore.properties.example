# Upload-signing config for Play. Copy to keystore.properties (git-ignored) and
# fill in with your own upload keystore. When keystore.properties is absent the
# release variant builds unsigned.
#
# Create an upload keystore once (interactive; pick strong passwords):
#
#   keytool -genkeypair -v \
#     -keystore upload.jks \
#     -alias beanbeaver-upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Then point storeFile at it (path relative to the repo root, or absolute).
# Back up the .jks + passwords somewhere safe; enroll in Play App Signing so a
# lost upload key can be reset by Google.

storeFile=upload.jks
storePassword=CHANGE_ME
keyAlias=beanbeaver-upload
keyPassword=CHANGE_ME
