# Standalone android/ ignores (also listed in parent .gitignore when co-located)
/target/
/.gradle/
/.kotlin/
**/build/
/local.properties
/captures/
/e2e-results/
/bbreceiptkit/src/main/jniLibs/
/bbreceiptkit/src/main/kotlin/uniffi/bb_receipt_ffi/
/bbreceiptkit/src/main/kotlin/com/beanbeaver/bbreceiptkit/BuildInfo.kt
/app/src/main/assets/models/
/models/*.onnx
*.apk
*.aab
# Upload-signing secrets — never commit. Config lives in keystore.properties;
# the keystore itself is a *.jks/*.keystore. See keystore.properties.example.
/keystore.properties
*.jks
*.keystore
*.iml
.idea/
.DS_Store
